@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dicbio: <http://dicbio.fflch.usp.br/ontology/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix lemonety: <http://lari-datasets.ilc.cnr.it/lemonEty#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dbauth: <http://dicbio.fflch.usp.br/autores/> .
@prefix lexinfo: <http://www.lexinfo.net/ontology/2.0/lexinfo#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix morph: <http://www.w3.org/ns/lemon/morph#> .
@prefix dbres: <http://dicbio.fflch.usp.br/recurso/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix nif: <http://persistence.uni-leipzig.org/nlp2rdf/ontologies/nif-core#> .
@prefix glotto: <https://glottolog.org/resource/languoid/id/> .
@prefix dbsrc: <http://dicbio.fflch.usp.br/fontes/> .



### --- Cabeçalho da ontologia ---

<http://dicbio.fflch.usp.br/ontology/>
    a owl:Ontology ;
    dcterms:title "Dicionário Histórico de Termos da Biologia" ;
    owl:versionInfo "0.4" ;
    dcterms:creator dbauth:bruno_maroneze ;
    owl:imports <http://www.w3.org/ns/lemon/ontolex> ;
    owl:imports <http://www.w3.org/ns/lemon/etym#> ;
    owl:imports <http://www.w3.org/ns/lemon/morph#> ;
    owl:imports <http://www.w3.org/ns/lemon/vartrans#> ;
    owl:imports <http://www.w3.org/2004/02/skos/core> ;
    owl:imports <http://purl.org/dc/terms/> .

### --- Classes e propriedades da ontologia ---

dicbio:SemanticEtymon a rdfs:Class ; # Classe criada para o artigo, preciso incluir nas instâncias
    rdfs:label "Semantic Etymon"@en, "Étimo Semântico"@pt ;
    rdfs:comment "A Semantic Etymon is a Lexical Sense that acts as a semantic source in an etymological relation to another Lexical Sense."@en ;
    rdfs:comment "Um Étimo Semântico é um Sentido Lexical que atua como origem semântica numa relação etimológica com outro Sentido Lexical."@pt ;
    rdfs:subClassOf ontolex:LexicalSense .

dicbio:semanticEtymon a owl:ObjectProperty ;
    rdfs:label "semantic etymon"@en, "étimo semântico"@pt ;
    rdfs:comment "Relates an etymology to a semantic etymon (a LexicalSense acting as an etymon)."@en ;
    rdfs:comment "Relaciona uma descrição etimológica a um étimo semântico (um Sentido Lexical que atua como um étimo)."@pt ;
    rdfs:domain lemonety:Etymology ;
    rdfs:range dicbio:SemanticEtymon ;
    rdfs:subPropertyOf lemonety:etymon .

dicbio:etymologicalArgumentation a owl:DatatypeProperty ;
    rdfs:domain lemonety:Etymology ;
    rdfs:range rdf:HTML ;
    rdfs:comment "Provides the discursive argumentation supporting or explaining the etymological hypothesis."@en .

dicbio:EtymologicalArgument a owl:Class ; # Criada para incluir argumentos a favor ou contra uma hipótese etimológica, em especial em casos de hipóteses concorrentes. Sugestão do ChatGPT. Precisamos ver exemplos concretos para entender a necessidade real de criar essa classe.
    rdfs:label "Etymological Argument"@en ;
    rdfs:comment "An argumentative unit that provides justification, evidence or reasoning in support of or against an etymological hypothesis."@en .

dicbio:evaluatesEtymology a owl:ObjectProperty ; # Relaciona um argumento a uma hipótese etimológica, indicando que o argumento é usado para apoiar ou refutar a hipótese. Eliminar se formos eliminar a classe EtymologicalArgument.
    rdfs:domain dicbio:EtymologicalArgument ;
    rdfs:range lemonety:Etymology ;
    rdfs:label "evaluates etymology"@en ;
    rdfs:comment "Relates an etymological argument to the etymological hypothesis that it supports or evaluates."@en .

dicbio:usesSource a owl:ObjectProperty ; # Indica que o argumento etimológico utiliza uma fonte documental ou bibliográfica como evidência. Eliminar se formos eliminar a classe EtymologicalArgument.
    rdfs:domain dicbio:EtymologicalArgument ;
    rdfs:range dcterms:BibliographicResource ;
    rdfs:comment "Indicates the documentary or bibliographic source used as evidence in the argument."@en .

# Esta e as propriedades seguintes podem ser usadas para classificar os argumentos etimológicos por tipo (e.g., fonológico, semântico, morfológico, documental) e para indicar o grau de certeza atribuído a uma hipótese etimológica com base nos argumentos apresentados. A necessidade de criar uma classe específica para os argumentos etimológicos depende do nível de detalhamento e da complexidade que queremos alcançar na representação das hipóteses etimológicas e dos seus fundamentos. Se decidirmos que é importante representar explicitamente os argumentos e as fontes que os sustentam, a criação dessa classe pode ser útil para organizar e estruturar essas informações de maneira clara e acessível. Caso contrário, podemos optar por incluir essas informações diretamente nas propriedades da classe Etymology, sem a necessidade de uma classe intermediária para os argumentos.
dicbio:ArgumentTypeScheme a skos:ConceptScheme ;
    rdfs:label "Argument Type Scheme"@en ;
    rdfs:comment "A scheme for classifying etymological arguments by their type (e.g., phonological, semantic, morphological, documentary)."@en .

dicbio:phonologicalArgument a skos:Concept ;
    skos:inScheme dicbio:ArgumentTypeScheme ;
    skos:prefLabel "Phonological argument"@en .

dicbio:semanticArgument a skos:Concept ;
    skos:inScheme dicbio:ArgumentTypeScheme ;
    skos:prefLabel "Semantic argument"@en .

dicbio:morphologicalArgument a skos:Concept ;
    skos:inScheme dicbio:ArgumentTypeScheme ;
    skos:prefLabel "Morphological argument"@en .

dicbio:documentaryArgument a skos:Concept ;
    skos:inScheme dicbio:ArgumentTypeScheme ;
    skos:prefLabel "Documentary argument"@en .

dicbio:argumentType a owl:ObjectProperty ;
    rdfs:domain dicbio:EtymologicalArgument ;
    rdfs:range skos:Concept ;
    rdfs:label "argument type"@en ;
    rdfs:comment "Specifies the type of etymological argument (phonological, semantic, morphological, documentary, etc.)."@en .

## --- aqui entram os graus de certeza etimológica

dicbio:EtymologicalCertaintyScheme a skos:ConceptScheme ;
    rdfs:label "Etymological Certainty Scheme"@en ;
    rdfs:label "Esquema de Certeza Etimológica"@pt ;
    rdfs:comment "A controlled vocabulary expressing the degree of certainty attributed to an etymological hypothesis based on the available evidence and its coherence with current scientific knowledge."@en ;
    rdfs:comment "Um vocabulário controlado que expressa o grau de certeza atribuída a uma hipótese etimológica com base nas evidências disponíveis e na sua coerência com o conhecimento científico atual."@pt .

dicbio:impossible a skos:Concept ;
    skos:inScheme dicbio:EtymologicalCertaintyScheme ;
    skos:prefLabel "Impossible"@en ;
    skos:prefLabel "Impossível"@pt ;
    skos:definition "The hypothesis contradicts established linguistic or historical evidence."@en ;
    skos:definition "A hipótese contradiz evidências linguísticas ou históricas estabelecidas."@pt .

dicbio:improbable a skos:Concept ;
    skos:inScheme dicbio:EtymologicalCertaintyScheme ;
    skos:prefLabel "Improbable"@en ;
    skos:prefLabel "Improvável"@pt ;
    skos:definition "The hypothesis lacks sufficient evidence or conflicts with current knowledge."@en ;
    skos:definition "A hipótese carece de evidências suficientes ou entra em contradição com o conhecimento atual."@pt .

dicbio:plausible a skos:Concept ;
    skos:inScheme dicbio:EtymologicalCertaintyScheme ;
    skos:prefLabel "Plausible"@en ;
    skos:prefLabel "Plausível"@pt ;
    skos:definition "The hypothesis is conceivable but weakly supported by evidence."@en ;
    skos:definition "A hipótese é concebível mas pouco apoiada por evidências."@pt .

dicbio:probable a skos:Concept ;
    skos:inScheme dicbio:EtymologicalCertaintyScheme ;
    skos:prefLabel "Probable"@en ;
    skos:prefLabel "Provável"@pt ;
    skos:definition "The hypothesis is supported by relevant evidence and is consistent with current knowledge."@en ;
    skos:definition "A hipótese é apoiada por evidências relevantes e é consistente com o conhecimento atual."@pt .

dicbio:certain a skos:Concept ;
    skos:inScheme dicbio:EtymologicalCertaintyScheme ;
    skos:prefLabel "Certain"@en ;
    skos:prefLabel "Certo"@pt ;
    skos:definition "The hypothesis is strongly supported by convergent evidence and is fully consistent with current scientific knowledge."@en ;
    skos:definition "A hipótese é fortemente apoiada por evidências convergentes e é totalmente consistente com o conhecimento científico atual."@pt .

dicbio:confidenceLevel a owl:ObjectProperty ;
    rdfs:domain lemonety:Etymology ;
    rdfs:range skos:Concept ;
    rdfs:label "confidence level"@en ;
    rdfs:comment "Indicates the degree of certainty attributed by the editors to an etymological hypothesis."@en .

## --- aqui entram os tipos de processos etimológicos 
# A propriedade lemonety:etyLinkType talvez já seja suficiente e não precisemos da propriedade dicbio:etymologicalProcess. Aqui, a ideia seria fazer uma lista fechada de processos, mas não sei se é mesmo necessário. Vamos manter apenas a propriedade lemonety:etyLinkType por enquanto, e depois verificamos se existe mesmo uma lista fechada de processos etimológicos que seja relevante para o nosso projeto e que justifique a criação de uma propriedade específica para isso.

dicbio:EtymologicalProcessScheme a skos:ConceptScheme ;
    rdfs:label "Etymological Process Scheme"@en ;
    rdfs:comment "A controlled vocabulary describing the type of etymological process involved in the formation of a lexical item."@en .

dicbio:inherited a skos:Concept ;
    skos:inScheme dicbio:EtymologicalProcessScheme ;
    skos:prefLabel "Inherited"@en ;
    skos:definition "The lexical item is inherited from an earlier stage of the same language."@en .

dicbio:borrowed a skos:Concept ;
    skos:inScheme dicbio:EtymologicalProcessScheme ;
    skos:prefLabel "Borrowed"@en ;
    skos:definition "The lexical item is borrowed from another language."@en .

dicbio:created a skos:Concept ;
    skos:inScheme dicbio:EtymologicalProcessScheme ;
    skos:prefLabel "Created"@en ;
    skos:definition "The lexical item was created within the language, e.g., through derivation, compounding or other kind of neological process."@en .

dicbio:semanticDerivation a skos:Concept ;
    skos:inScheme dicbio:EtymologicalProcessScheme ;
    skos:prefLabel "Derived from another sense"@en ;
    skos:definition "The lexical item was derived from another lexical sense in the same language."@en .

dicbio:etymologicalProcess a owl:ObjectProperty ;
    rdfs:domain lemonety:Etymology ;
    rdfs:range skos:Concept ;
    rdfs:label "etymological process"@en ;
    rdfs:comment "Specifies the type of historical process involved in an etymological hypothesis (e.g., inheritance, borrowing, internal creation). The process is attributed to the hypothesis, not directly to the lexical entry."@en .

dicbio:semanticDerivationFrom a owl:ObjectProperty ;
    rdfs:domain lemonety:Etymology ;
    rdfs:range ontolex:LexicalSense ;
    rdfs:label "semantic derivation from"@en ;
    rdfs:comment "Relates an etymological hypothesis to the lexical sense from which another sense is assumed to have historically developed through a diachronic semantic change (e.g., specialization, generalization, metaphor, metonymy). This property models historical semantic development, not merely synchronic semantic relatedness."@en .

dicbio:hasWordFormationRelation a owl:ObjectProperty ;
    rdfs:domain lemonety:Etymology ;
    rdfs:range morph:WordFormationRelation ;
    rdfs:label "has word formation relation"@en ;
    rdfs:comment "Links an etymological hypothesis to a morphological word formation relation that describes the internal formation of the lexical item."@en .

### Explains which sense is being analyzed

dicbio:explainsSense a owl:ObjectProperty ;
    rdfs:domain lemonety:Etymology ;
    rdfs:range ontolex:LexicalSense ;
    rdfs:label "explains sense"@en ;
    rdfs:comment "Relates an etymological hypothesis to the lexical sense whose historical origin it aims to explain."@en .


### Indicates the historical source sense

dicbio:derivesFromSense a owl:ObjectProperty ;
    rdfs:domain lemonety:Etymology ;
    rdfs:range ontolex:LexicalSense ;
    rdfs:label "derives from sense"@en ;
    rdfs:comment "Relates an etymological hypothesis to the lexical sense from which another sense is assumed to have historically developed through a diachronic semantic change."@en .


## Aqui entram os conceitos e propriedades para incluir as atestações históricas de uso dos termos, quando disponíveis

dicbio:Attestation a owl:Class ;
    rdfs:label "Attestation"@en ;
    rdfs:label "Atestação"@pt ;
    rdfs:comment "Registro de datação histórica de uma acepção de uma unidade lexical, baseado em uma fonte específica."@pt ;
    rdfs:subClassOf prov:Entity .

dicbio:hasAttestation a owl:ObjectProperty ;
    rdfs:label "has attestation"@en ;
    rdfs:label "tem atestação"@pt ;
    rdfs:comment "Relaciona um sentido lexical (acepção) a um registro de atestação histórica."@pt ;
    rdfs:domain ontolex:LexicalSense ;
    rdfs:range dicbio:Attestation .

dicbio:hasOccurrence a owl:ObjectProperty ;
    rdfs:label "has occurrence"@en ;
    rdfs:label "tem ocorrência"@pt ;
    rdfs:comment "Relaciona um registro de atestação histórica a uma ocorrência específica de uma unidade lexical em um documento ou fonte."@pt ;
    rdfs:domain dicbio:Attestation ;
    rdfs:range nif:Word .

dicbio:attestationDate a owl:DatatypeProperty ;
    rdfs:label "attestation date"@en ;
    rdfs:label "data de atestação"@pt ;
    rdfs:comment "Data associada à atestação histórica da unidade lexical."@pt ;
    rdfs:domain dicbio:Attestation ;
    rdfs:range xsd:gYear .
