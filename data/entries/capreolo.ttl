### --- VERBETE: CAPREOLO ---

dbres:entry_capreolo a ontolex:LexicalEntry ;
    dcterms:created "2022-02-28"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze ;
    lexinfo:gender lexinfo:masculine ;
    lexinfo:partOfSpeech lexinfo:noun ;
    ontolex:canonicalForm dbres:form_capreolo ;
    ontolex:otherForm dbres:form_capreolos ;
    ontolex:sense dbres:entry_capreolo_sense1 .

dbres:etym_capreolo_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_capreolus ;
    dicbio:etymologicalArgumentation "O étimo é o latim científico <i>capreolus</i>, sinônimo de “cirro”, conforme define o próprio Vandelli: “<i>Capreoli, carbiculae, viticuli:</i> O mesmo, que os <i>cirrhos.</i> Ou he <i>o cirro.</i>” (Diccionario dos termos technicos de Historia Natural, 1788, p. 236). O dicionário de Gaffiot afirma que a palavra já tinha o sentido de \"gavinha da videira\" no latim da Antiguidade, embora também pudesse significar \"cabrito\".<br>O Dicionário Houaiss não inclui esse verbete em sua nomenclatura. O Dicionário Aulete inclui apenas com a acepção de \"espécie de cabra\". É possível que a acepção da Botânica esteja em desuso no português contemporâneo."^^rdf:HTML .

dbres:etymon_capreolus a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source dbsrc:source_vandelli ;
    ontolex:writtenRep "capreolus" .

dbres:form_capreolo a ontolex:Form ;
    ontolex:writtenRep "capréolo"@pt .

dbres:form_capreolos a ontolex:Form ;
    rdfs:label "plural"@pt ;
    ontolex:writtenRep "capreolos"@pt .

dbres:entry_capreolo_sense1 a ontolex:LexicalSense ;
    skos:definition "O mesmo que cirro (acepção 2)."@pt ;
    lemonety:etymology dbres:etym_capreolo_sense1 .

