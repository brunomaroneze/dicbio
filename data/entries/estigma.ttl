### --- VERBETE: ESTIGMA ---

dbres:entry_estigma a ontolex:LexicalEntry ;
    dcterms:created "2022-02-28"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze ;
    lexinfo:gender lexinfo:masculine ;
    lexinfo:partOfSpeech lexinfo:noun ;
    ontolex:canonicalForm dbres:form_estigma ;
    ontolex:otherForm dbres:form_estigmas ;
    ontolex:sense dbres:entry_estigma_sense1 .

dbres:etym_estigma_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_stigma ;
    dicbio:etymologicalArgumentation "O étimo é o latim <i>stigma, atis</i>, conforme informa o Dicionário Houaiss, que já era empregado, no latim científico do século XVIII, com o sentido que tem na Botânica. A data informada pelo Dicionário Houaiss é possivelmente para outra acepção da mesma palavra."^^rdf:HTML .

dbres:etymon_stigma a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source "Dicionário Houaiss" ;
    ontolex:writtenRep "stigma" .

dbres:form_estigma a ontolex:Form ;
    ontolex:writtenRep "estigma"@pt .

dbres:form_estigmas a ontolex:Form ;
    rdfs:label "plural"@pt ;
    ontolex:writtenRep "estigmas"@pt .

dbres:entry_estigma_sense1 a ontolex:LexicalSense ;
    skos:definition "Parte superior do pistilo, rica em uma substância líquida e pegajosa que capta os grãos de pólen para a fecundação."@pt ;
    lemonety:etymology dbres:etym_estigma_sense1 .

