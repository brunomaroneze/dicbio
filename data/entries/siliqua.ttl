### --- VERBETE: SILIQUA ---

dbres:entry_siliqua a ontolex:LexicalEntry ;
    dcterms:created "2022-02-28"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze ;
    lexinfo:gender lexinfo:feminine ;
    lexinfo:partOfSpeech lexinfo:noun ;
    ontolex:canonicalForm dbres:form_siliqua ;
    ontolex:otherForm dbres:form_siliqua,
        dbres:form_siliquas ;
    ontolex:sense dbres:entry_siliqua_sense1 .

dbres:etym_siliqua_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_siliqua ;
    dicbio:etymologicalArgumentation "O étimo é o latim <i>siliqua,ae</i> \"vagem\", empregado desde a Antiguidade (como atesta o dicionário de Gaffiot), mas que no latim científico adquire uma acepção mais precisa no âmbito da Botânica e, assim, passa ao português."^^rdf:HTML .

dbres:etymon_siliqua a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source dbsrc:source_gaffiot ;
    ontolex:writtenRep "siliqua" .

dbres:form_siliqua a ontolex:Form ;
    ontolex:writtenRep "siliqua"@pt,
        "síliqua"@pt .

dbres:form_siliquas a ontolex:Form ;
    rdfs:label "plural"@pt ;
    ontolex:writtenRep "siliquas"@pt .

dbres:entry_siliqua_sense1 a ontolex:LexicalSense ;
    skos:definition "Pericarpo de duas valvas, côncavo, cujo comprimento excede a largura, com sementes presas ao longo das suturas."@pt ;
    lemonety:etymology dbres:etym_siliqua_sense1 .

