### --- VERBETE: POLPA ---

dbres:entry_polpa a ontolex:LexicalEntry ;
    dcterms:created "2023-09-21"^^xsd:date ;
    dcterms:creator dbauth:adriane_queiroz,
        dbauth:bruno_maroneze,
        dbauth:matheus_casarin ;
    lexinfo:gender lexinfo:feminine ;
    lexinfo:partOfSpeech lexinfo:noun ;
    ontolex:canonicalForm dbres:form_polpa ;
    ontolex:sense dbres:entry_polpa_sense1 .

dbres:etym_polpa_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_pulpa ;
    dicbio:etymologicalArgumentation "O étimo é o substantivo latino <i>pulpa, ae</i>, que, no latim da Antiguidade, significava “parte carnosa do corpo” e, por extensão, “parte carnosa de um fruto” (segundo o Oxford Latin Dictionary). A alternância -u- para -o- sugere tratar-se de palavra herdada, ainda que sua atestação seja tardia (século XVI, segundo o dicionário Houaiss). Nos textos de Vandelli e Brotero, “polpa” se refere não só à parte carnosa dos frutos, mas também de outras estruturas vegetais, como certas folhas de plantas suculentas."^^rdf:HTML .

dbres:etymon_pulpa a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source dbsrc:source_old ;
    ontolex:writtenRep "pulpa" .

dbres:form_polpa a ontolex:Form ;
    ontolex:writtenRep "polpa"@pt .

dbres:entry_polpa_sense1 a ontolex:LexicalSense ;
    skos:definition "Substância espessa presente em certas estruturas vegetais, como folhas e frutos."@pt ;
    lemonety:etymology dbres:etym_polpa_sense1 .

