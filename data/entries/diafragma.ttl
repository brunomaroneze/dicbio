### --- VERBETE: DIAFRAGMA ---
### Falta revisar a etimologia para a acepção 2

dbres:entry_diafragma a ontolex:LexicalEntry ;
    dcterms:created "2022-07-26"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze,
        dbauth:raissa_buss ;
    lexinfo:gender lexinfo:masculine ;
    lexinfo:partOfSpeech lexinfo:noun ;
    ontolex:canonicalForm dbres:form_diafragma ;
    ontolex:otherForm dbres:form_diafragmas,
        dbres:form_diaphragma ;
    ontolex:sense dbres:entry_diafragma_sense1,
        dbres:entry_diafragma_sense2 .

dbres:etym_diafragma_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_diaphragma ;
    dicbio:etymologicalArgumentation "O étimo é o latim <i>diaphragma</i>, que, segundo o dicionário de Gaffiot, é atestado na obra de Célio Aureliano (século V d.C), já designando o mesmo músculo; em latim, por sua vez, a palavra é um empréstimo do grego, significando “divisão” ou “barreira”, mas já designando o mesmo músculo em Platão e em Galeno (conforme informa o dicionário de Liddell, Scott e Jones). Em português, trata-se certamente de um latinismo que entrou provavelmente por meio do latim científico."^^rdf:HTML .

dbres:etymon_diaphragma a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source dbsrc:source_gaffiot ;
    ontolex:writtenRep "diaphragma" .

dbres:form_diafragma a ontolex:Form ;
    ontolex:writtenRep "diafragma"@pt .

dbres:form_diafragmas a ontolex:Form ;
    rdfs:label "plural"@pt ;
    ontolex:writtenRep "diafragmas"@pt .

dbres:form_diaphragma a ontolex:Form ;
    ontolex:writtenRep "Diaphragma"@pt,
        "diaphragma"@pt .

dbres:entry_diafragma_sense1 a ontolex:LexicalSense ;
    skos:definition "Músculo em formato de abóbada que separa a região torácica do abdome."@pt ;
    lemonety:etymology dbres:etym_diafragma_sense1 .

dbres:entry_diafragma_sense2 a ontolex:LexicalSense ;
    skos:definition "Membrana que separa duas ou mais cavidades, em certos animais (como moluscos) e vegetais (como cavidades em frutos)."@pt .

