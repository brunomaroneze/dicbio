### --- VERBETE: CUTICULA ---

dbres:entry_cuticula a ontolex:LexicalEntry ;
    dcterms:created "2022-02-28"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze ;
    lexinfo:gender lexinfo:feminine ;
    lexinfo:partOfSpeech lexinfo:noun ;
    ontolex:canonicalForm dbres:form_cuticula ;
    ontolex:otherForm dbres:form_cuticula ;
    ontolex:sense dbres:entry_cuticula_sense1 .

dbres:etym_cuticula_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_cuticula ;
    dicbio:etymologicalArgumentation "O étimo é o latim <i>cuticula,ae</i>, diminutivo de <i>cutis,i</i>, que significa \"pele\". A atestação informada pelo Dicionário Houaiss é possivelmente para uma acepção fora da Botânica. A ocorrência em Vandelli talvez seja a primeira atestação no âmbito da Botânica."^^rdf:HTML .

dbres:etymon_cuticula a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source dbsrc:source_vandelli ;
    ontolex:writtenRep "cuticula" .

dbres:form_cuticula a ontolex:Form ;
    ontolex:writtenRep "cuticula"@pt,
        "cutícula"@pt .

dbres:entry_cuticula_sense1 a ontolex:LexicalSense ;
    skos:definition "Membrana que reveste a raiz das plantas, por cima da casca."@pt ;
    lemonety:etymology dbres:etym_cuticula_sense1 .

