### --- VERBETE: ELONGADO ---

dbres:entry_elongado a ontolex:LexicalEntry ;
    dcterms:created "2023-09-25"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze,
        dbauth:kamila_barbosa ;
    lexinfo:partOfSpeech lexinfo:adjective ;
    ontolex:canonicalForm dbres:form_elongado ;
    ontolex:otherForm dbres:form_elongada ;
    ontolex:sense dbres:entry_elongado_sense1 .

dbres:etym_elongado_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_elongatus ;
    dicbio:etymologicalArgumentation "O étimo é, muito provavelmente, o latim <i>elongatus</i> (particípio do verbo latino <i>elongo, are</i>, atestado, segundo o dicionário de Gaffiot, no texto da Vulgata); assim, trata-se de um decalque do latim. É possível hipotetizar que o verbo <i>elongar</i> seja uma retroformação a partir de <i>elongado</i>, mas sem datações confiáveis para o verbo, ainda não é possível afirmar com certeza."^^rdf:HTML .

dbres:etymon_elongatus a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source dbsrc:source_gaffiot ;
    ontolex:writtenRep "elongatus" .

dbres:form_elongado a ontolex:Form ;
    ontolex:writtenRep "elongado"@pt .

dbres:form_elongada a ontolex:Form ;
    rdfs:label "feminino singular"@pt ;
    ontolex:writtenRep "elongada"@pt .

dbres:entry_elongado_sense1 a ontolex:LexicalSense ;
    skos:definition "Que se alonga, que é comprido."@pt ;
    lemonety:etymology dbres:etym_elongado_sense1 .

