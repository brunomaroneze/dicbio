### --- VERBETE: PILOSO ---

dbres:entry_piloso a ontolex:LexicalEntry ;
    dcterms:created "2022-02-28"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze ;
    lexinfo:partOfSpeech lexinfo:adjective ;
    ontolex:canonicalForm dbres:form_piloso ;
    ontolex:otherForm dbres:form_pillosa,
        dbres:form_pilosas ;
    ontolex:sense dbres:entry_piloso_sense1 .

dbres:etym_piloso_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_pilosus ;
    dicbio:etymologicalArgumentation "O étimo é o latim científico <i>pilosus,a,um</i>, com o mesmo sentido, conforme atesta o próprio dicionário de Vandelli. A palavra latina já era usada na Antiguidade com o sentido de “peludo, coberto de pelos” (conforme se lê no dicionário de Gaffiot), mas o termo português é claramente um empréstimo do latim científico, e não uma palavra herdada."^^rdf:HTML .

dbres:etymon_pilosus a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source "Vandelli" ;
    ontolex:writtenRep "pilosus" .

dbres:form_piloso a ontolex:Form ;
    ontolex:writtenRep "piloso"@pt .

dbres:form_pillosa a ontolex:Form ;
    rdfs:label "feminino singular"@pt ;
    ontolex:writtenRep "pillosa"@pt .

dbres:form_pilosas a ontolex:Form ;
    rdfs:label "feminino plural"@pt ;
    ontolex:writtenRep "pilosas"@pt .

dbres:entry_piloso_sense1 a ontolex:LexicalSense ;
    skos:definition "Coberto de estruturas semelhantes a pelos (diz-se de folha)."@pt ;
    lemonety:etymology dbres:etym_piloso_sense1 .

