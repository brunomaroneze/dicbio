### --- VERBETE: PEDUNCULO ---
### Falta acertar a etimologia da acepção 2.

dbres:entry_pedunculo a ontolex:LexicalEntry ;
    dcterms:created "2022-02-28"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze ;
    lexinfo:gender lexinfo:masculine ;
    lexinfo:partOfSpeech lexinfo:noun ;
    ontolex:canonicalForm dbres:form_pedunculo ;
    ontolex:otherForm dbres:form_pedunculo,
        dbres:form_pedunculos ;
    ontolex:sense dbres:entry_pedunculo_sense1,
        dbres:entry_pedunculo_sense2 .

dbres:etym_pedunculo_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_pedunculus ;
    dicbio:etymologicalArgumentation "Conforme explica o Dicionário Houaiss, o étimo é o latim <i>pedunculus,i</i>, diminutivo de <i>pes,pedis</i> (que significa \"pé\"). O dicionário de Gaffiot informa que <i>pedunculus</i> ou <i>pediculus</i> já na Antiguidade era empregado com o sentido de \"pedúnculo, haste de uma folha\", mas o étimo do termo português é, evidentemente, o latim científico, visto que a palavra não é herdada. Vandelli distingue (embora nem sempre com muita clareza) os conceitos de <i>pedúnculo</i> (haste da frutificação), <i>pecíolo</i> (haste da folha) e <i>pedicelo</i> (ramo de um pedúnculo). Já a definição de Morais Silva não é tão clara, aparentemente confundindo os conceitos."^^rdf:HTML .

dbres:etymon_pedunculus a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source dbsrc:source_gaffiot ;
    ontolex:writtenRep "pedunculus" .

dbres:form_pedunculo a ontolex:Form ;
    ontolex:writtenRep "Pedunculo"@pt,
        "pedunculo"@pt,
        "pedúnculo"@pt .

dbres:form_pedunculos a ontolex:Form ;
    rdfs:label "plural"@pt ;
    ontolex:writtenRep "pedunculos"@pt .

dbres:entry_pedunculo_sense1 a ontolex:LexicalSense ;
    skos:definition "Estrutura semelhante a um ramo, que sustenta a inflorescência e a frutificação."@pt ;
    lemonety:etymology dbres:etym_pedunculo_sense1 .

dbres:entry_pedunculo_sense2 a ontolex:LexicalSense ;
    skos:definition "Haste que sustenta diversas estruturas dos insetos, como antenas, olhos ou o abdômen."@pt .

