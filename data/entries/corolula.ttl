### --- VERBETE: COROLULA ---

dbres:entry_corolula a ontolex:LexicalEntry ;
    dcterms:created "2024-11-26"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze ;
    lexinfo:gender lexinfo:feminine ;
    lexinfo:partOfSpeech lexinfo:noun ;
    ontolex:canonicalForm dbres:form_corolula ;
    ontolex:otherForm dbres:form_corollulas ;
    ontolex:sense dbres:entry_corolula_sense1 .

dbres:etym_corolula_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_corollula ;
    dicbio:etymologicalArgumentation "O étimo é o latim científico <i>corollula</i>, atestado no século XVIII (como, por exemplo, na obra <i>Genera Plantarum</i>, de Lineu - https://www.google.com.br/books/edition/Genera_plantarum/tX0ZAAAAYAAJ). Trata-se do diminutivo de <i>corolla</i>, esta última já um diminutivo (de <i>corona</i>, coroa).<br>O termo não aparece em textos de Botânica em pesquisas recentes no Google, o que leva a crer que não é mais usado atualmente."^^rdf:HTML .

dbres:etymon_corollula a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source "<i>Genera Plantarum</i>, de Lineu - https://www.google.com.br/books/edition/Genera_plantarum/tX0ZAAAAYAAJ" ;
    ontolex:writtenRep "corollula" .

dbres:form_corolula a ontolex:Form ;
    ontolex:writtenRep "corólula"@pt .

dbres:form_corollulas a ontolex:Form ;
    rdfs:label "plural"@pt ;
    ontolex:writtenRep "corollulas"@pt .

dbres:entry_corolula_sense1 a ontolex:LexicalSense ;
    skos:definition "Corola pequena."@pt ;
    lemonety:etymology dbres:etym_corolula_sense1 .

