### --- VERBETE: PELVE ---
### A etimologia apresentada refere-se à acepção 1. Falta a etimologia da acepção 2.

dbres:entry_pelve a ontolex:LexicalEntry ;
    dcterms:created "2025-07-06"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze,
        dbauth:geovanna_lima ;
    lexinfo:gender lexinfo:feminine ;
    lexinfo:partOfSpeech lexinfo:noun ;
    ontolex:canonicalForm dbres:form_pelve ;
    ontolex:sense dbres:entry_pelve_sense1,
        dbres:entry_pelve_sense2 .

dbres:etym_pelve_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_pelvis ;
    dicbio:etymologicalArgumentation "O étimo é o latim <i>pelvis</i>, que se refere a \"bacia de metal; caldeirão\", conforme registrado no dicionário de Gaffiot. No entanto, não há registros da forma latina <i>pelvis</i> com o sentido de \"cavidade óssea\" nos dicionários de latim da Antiguidade (Gaffiot e Oxford Latin Dictionary), o que leva a crer que o étimo da forma portuguesa nessa acepção surge nos textos do latim científico, já que é possível encontrar textos técnicos do século XVII em que o termo ocorre, como, por exemplo, em \"Opera Omnia\" (1687), de Marcello Malpighi (https://www.google.com.br/books/edition/Opera_omnia/jyNAAAAAcAAJ)."^^rdf:HTML .

dbres:etymon_pelvis a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source "\"Opera Omnia\" (1687), de Marcello Malpighi (https://www.google.com.br/books/edition/Opera_omnia/jyNAAAAAcAAJ" ;
    ontolex:writtenRep "pelvis" .

dbres:form_pelve a ontolex:Form ;
    ontolex:writtenRep "pelve"@pt .

dbres:entry_pelve_sense1 a ontolex:LexicalSense ;
    skos:definition "Estrutura óssea em formato de bacia presente nos quadris."@pt ;
    lemonety:etymology dbres:etym_pelve_sense1 .

dbres:entry_pelve_sense2 a ontolex:LexicalSense ;
    skos:definition "Cavidade em formato de bacia presente nos rins."@pt .

