### --- VERBETE: DESENVOLUCAO ---

dbres:entry_desenvolucao a ontolex:LexicalEntry ;
    dcterms:created "2025-03-26"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze ;
    lexinfo:gender lexinfo:feminine ;
    lexinfo:partOfSpeech lexinfo:noun ;
    ontolex:canonicalForm dbres:form_desenvolucao ;
    ontolex:otherForm dbres:form_desenvolucao ;
    ontolex:sense dbres:entry_desenvolucao_sense1 .

dbres:etym_desenvolucao_sense1 a lemonety:Etymology ;
    lemonety:etymon <http://dicbio.fflch.usp.br/recurso/etymon_desenvolver_+_-cao> ;
    dicbio:etymologicalArgumentation "A ausência de cognatos em latim ou em outras línguas românicas parece indicar que se trata de criação portuguesa. A existência prévia de <i>desenvolver</i> (datado do século XIV, segundo o dicionário Houaiss), mas não de <i>*envolução</i>, leva a crer que se trata, morfológica e etimologicamente, de uma derivação sufixal a partir do verbo <i>desenvolver</i>, sob o modelo de <i>revolução</i>, <i>evolução</i> etc.<br>O termo caiu em desuso em favor da forma <i>desenvolvimento</i>, mais antiga (século XV, segundo o dicionário Houaiss) e mais frequente."^^rdf:HTML .

<http://dicbio.fflch.usp.br/recurso/etymon_desenvolver_+_-cao> a lemonety:Etymon ;
    dcterms:language "formação vernácula" ;
    dcterms:source "Dicionário Houaiss" ;
    ontolex:writtenRep "desenvolver + -ção" .

dbres:form_desenvolucao a ontolex:Form ;
    ontolex:writtenRep "desenvoluçaõ"@pt,
        "desenvolução"@pt .

dbres:entry_desenvolucao_sense1 a ontolex:LexicalSense ;
    skos:definition "Ação de desenvolver; desenvolvimento."@pt ;
    lemonety:etymology dbres:etym_desenvolucao_sense1 .

