### --- VERBETE: FLOSCULO ---

dbres:entry_flosculo a ontolex:LexicalEntry ;
    dcterms:created "2022-02-28"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze ;
    lexinfo:gender lexinfo:masculine ;
    lexinfo:partOfSpeech lexinfo:noun ;
    ontolex:canonicalForm dbres:form_flosculo ;
    ontolex:otherForm dbres:form_flosculos ;
    ontolex:sense dbres:entry_flosculo_sense1 .

dbres:etym_flosculo_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_flosculus ;
    dicbio:etymologicalArgumentation "O étimo, conforme aponta o Dicionário Houaiss, é o latim <i>flosculus, i</i>, diminutivo de <i>flos, oris</i> \"flor\". O termo latino <i>flosculus</i> é referenciado no índice do dicionário de Vandelli, mas não aparece descrito em sua nomenclatura."^^rdf:HTML .

dbres:etymon_flosculus a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source dbsrc:source_vandelli ;
    ontolex:writtenRep "flosculus" .

dbres:form_flosculo a ontolex:Form ;
    ontolex:writtenRep "flósculo"@pt .

dbres:form_flosculos a ontolex:Form ;
    rdfs:label "plural"@pt ;
    ontolex:writtenRep "flosculos"@pt .

dbres:entry_flosculo_sense1 a ontolex:LexicalSense ;
    skos:definition "Pequena flor."@pt ;
    lemonety:etymology dbres:etym_flosculo_sense1 .

