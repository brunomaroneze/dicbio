### --- VERBETE: MEMBRANACEO ---

dbres:entry_membranaceo a ontolex:LexicalEntry ;
    dcterms:created "2022-02-28"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze ;
    lexinfo:partOfSpeech lexinfo:adjective ;
    ontolex:canonicalForm dbres:form_membranaceo ;
    ontolex:otherForm dbres:form_membranacea,
        dbres:form_membranaceas,
        dbres:form_membranaceo,
        dbres:form_membranaceos ;
    ontolex:sense dbres:entry_membranaceo_sense1 .

dbres:etym_membranaceo_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_membranaceus ;
    dicbio:etymologicalArgumentation "Conforme informa o Dicionário Houaiss, o étimo é o latim <i>membranaceus,a,um</i>, que significa \"feito de uma membrana, formado de uma membrana; liso como uma membrana\", já empregado no latim científico, conforme atesta a obra de Vandelli. O sinônimo “membranoso” também ocorre em Vandelli, na parte reservada à Zoologia."^^rdf:HTML .

dbres:etymon_membranaceus a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source "Vandelli" ;
    ontolex:writtenRep "membranaceus" .

dbres:form_membranaceo a ontolex:Form ;
    ontolex:writtenRep "Membranaceo"@pt,
        "membranaceo"@pt,
        "membranáceo"@pt .

dbres:form_membranacea a ontolex:Form ;
    rdfs:label "feminino singular"@pt ;
    ontolex:writtenRep "Membranacea"@pt,
        "membranacea"@pt .

dbres:form_membranaceas a ontolex:Form ;
    rdfs:label "feminino plural"@pt ;
    ontolex:writtenRep "Membranaceas"@pt,
        "membranaceas"@pt .

dbres:form_membranaceos a ontolex:Form ;
    rdfs:label "masculino plural"@pt ;
    ontolex:writtenRep "membranaceos"@pt .

dbres:entry_membranaceo_sense1 a ontolex:LexicalSense ;
    skos:definition "Delgado, comprido, em formato de lâmina ou membrana."@pt ;
    lemonety:etymology dbres:etym_membranaceo_sense1 .

