### --- VERBETE: OBLONGO ---

dbres:entry_oblongo a ontolex:LexicalEntry ;
    dcterms:created "2022-02-28"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze ;
    lexinfo:partOfSpeech lexinfo:adjective ;
    ontolex:canonicalForm dbres:form_oblongo ;
    ontolex:otherForm dbres:form_oblonga,
        dbres:form_oblongas,
        dbres:form_oblongos ;
    ontolex:sense dbres:entry_oblongo_sense1 .

dbres:etym_oblongo_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_oblongus ;
    dicbio:etymologicalArgumentation "O étimo é o latim <i>oblongus,a,um</i>, com o mesmo sentido, já empregado na Botânica no século XVIII, como atesta o próprio dicionário de Vandelli (por exemplo, à p. 214). Entrou na língua portuguesa como um empréstimo, provavelmente do latim científico. A atestação mais antiga informada pelo Dicionário Houaiss é possivelmente para outra acepção."^^rdf:HTML .

dbres:etymon_oblongus a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source dbsrc:source_vandelli ;
    ontolex:writtenRep "oblongus" .

dbres:form_oblongo a ontolex:Form ;
    ontolex:writtenRep "oblongo"@pt .

dbres:form_oblonga a ontolex:Form ;
    rdfs:label "feminino singular"@pt ;
    ontolex:writtenRep "Oblonga"@pt,
        "oblonga"@pt .

dbres:form_oblongas a ontolex:Form ;
    rdfs:label "feminino plural"@pt ;
    ontolex:writtenRep "Oblongas"@pt .

dbres:form_oblongos a ontolex:Form ;
    rdfs:label "masculino plural"@pt ;
    ontolex:writtenRep "Oblongos"@pt .

dbres:entry_oblongo_sense1 a ontolex:LexicalSense ;
    skos:definition "Cujo diâmetro longitudinal excede o transversal (diz-se de folha ou de outras estruturas vegetais)."@pt ;
    lemonety:etymology dbres:etym_oblongo_sense1 .

