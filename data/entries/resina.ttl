### --- VERBETE: RESINA ---

dbres:entry_resina a ontolex:LexicalEntry ;
    dcterms:created "2022-04-24"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze ;
    lexinfo:gender lexinfo:feminine ;
    lexinfo:partOfSpeech lexinfo:noun ;
    ontolex:canonicalForm dbres:form_resina ;
    ontolex:otherForm dbres:form_rezina ;
    ontolex:sense dbres:entry_resina_sense1 .

dbres:etym_resina_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_resina ;
    dicbio:etymologicalArgumentation "O étimo é a forma latina <i>resīna,ae</i> (com o mesmo sentido), atestada desde a Antiguidade, segundo o Oxford Latin Dictionary. A julgar pela permanência do -n- intervocálico na forma portuguesa, a palavra deve ser considerada erudita (ainda que atestada desde a Idade Média, segundo o dicionário Houaiss), ou, talvez, uma reconstituição erudita posterior (visto que o mesmo dicionário informa que a forma medieval é <i>resia</i>)."^^rdf:HTML .

dbres:etymon_resina a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source dbsrc:source_old ;
    ontolex:writtenRep "resina" .

dbres:form_resina a ontolex:Form ;
    ontolex:writtenRep "resina"@pt .

dbres:form_rezina a ontolex:Form ;
    ontolex:writtenRep "rezina"@pt .

dbres:entry_resina_sense1 a ontolex:LexicalSense ;
    skos:definition "Substância produzida por certas plantas, inflamável, insolúvel na água e solúvel no álcool."@pt ;
    lemonety:etymology dbres:etym_resina_sense1 .

