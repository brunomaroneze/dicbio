### --- VERBETE: CILIADO ---

dbres:entry_ciliado a ontolex:LexicalEntry ;
    dcterms:created "2023-09-25"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze,
        dbauth:kamila_barbosa ;
    lexinfo:partOfSpeech lexinfo:adjective ;
    ontolex:canonicalForm dbres:form_ciliado ;
    ontolex:otherForm dbres:form_ciliada,
        dbres:form_ciliadas,
        dbres:form_ciliados ;
    ontolex:sense dbres:entry_ciliado_sense1 .

dbres:etym_ciliado_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_ciliatus ;
    dicbio:etymologicalArgumentation "Há duas possibilidades de descrição do étimo: 1 - pode ser analisado como um decalque do latim <i>cĭlĭātus</i> (atestado na Antiguidade, conforme registrado no dicionário de Gaffiot), que teria entrado na língua portuguesa por meio do latim científico (visto não ser palavra herdada, como se percebe pela conservação do -l- intervocálico); ou 2 - como adjetivo derivado do substantivo <i>cílio</i> acrescido do sufixo -<i>ado</i>, visto que o substantivo teve, segundo o Dicionário Houaiss, sua primeira atestação em 1344; portanto, no momento da elaboração do dicionário de Vandelli, há a possibilidade de o autor ter utilizado o recurso da própria língua portuguesa para introduzir a palavra na língua através do processo de derivação."^^rdf:HTML .

dbres:etymon_ciliatus a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source dbsrc:source_gaffiot ;
    ontolex:writtenRep "ciliatus" .

dbres:form_ciliado a ontolex:Form ;
    ontolex:writtenRep "ciliado"@pt .

dbres:form_ciliada a ontolex:Form ;
    rdfs:label "feminino singular"@pt ;
    ontolex:writtenRep "Ciliada"@pt .

dbres:form_ciliadas a ontolex:Form ;
    rdfs:label "feminino plural"@pt ;
    ontolex:writtenRep "Ciliadas"@pt .

dbres:form_ciliados a ontolex:Form ;
    rdfs:label "masculino plural"@pt ;
    ontolex:writtenRep "Ciliados"@pt,
        "ciliados"@pt .

dbres:entry_ciliado_sense1 a ontolex:LexicalSense ;
    skos:definition "Provido de, ou em forma de cílios."@pt ;
    lemonety:etymology dbres:etym_ciliado_sense1 .

