### --- VERBETE: ESTIPULA ---

dbres:entry_estipula a ontolex:LexicalEntry ;
    dcterms:created "2022-02-28"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze ;
    lexinfo:gender lexinfo:feminine ;
    lexinfo:partOfSpeech lexinfo:noun ;
    ontolex:canonicalForm dbres:form_estipula ;
    ontolex:otherForm dbres:form_estipulas ;
    ontolex:sense dbres:entry_estipula_sense1 .

dbres:etym_estipula_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_stipula ;
    dicbio:etymologicalArgumentation "O étimo é o latim <i>stipula</i>, cujo sentido original de \"haste dos cereais\" remonta à Antiguidade; no entanto, o seu emprego científico como termo da Botânica deriva do latim científico (como atesta a própria obra de Vandelli), sendo, portanto, empréstimo do latim."^^rdf:HTML .

dbres:etymon_stipula a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source dbsrc:source_vandelli ;
    ontolex:writtenRep "stipula" .

dbres:form_estipula a ontolex:Form ;
    ontolex:writtenRep "estípula"@pt .

dbres:form_estipulas a ontolex:Form ;
    rdfs:label "plural"@pt ;
    ontolex:writtenRep "estipulas"@pt .

dbres:entry_estipula_sense1 a ontolex:LexicalSense ;
    skos:definition "Escama que nasce na base do pecíolo ou do pedúnculo."@pt ;
    lemonety:etymology dbres:etym_estipula_sense1 .

