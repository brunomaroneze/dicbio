### --- VERBETE: UMBILICADO ---

dbres:entry_umbilicado a ontolex:LexicalEntry ;
    dcterms:created "2023-09-25"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze,
        dbauth:kamila_barbosa ;
    lexinfo:partOfSpeech lexinfo:adjective ;
    ontolex:canonicalForm dbres:form_umbilicado ;
    ontolex:otherForm dbres:form_umbilicada,
        dbres:form_umbilicadas ;
    ontolex:sense dbres:entry_umbilicado_sense1 .

dbres:etym_umbilicado_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_umbilicatus ;
    dicbio:etymologicalArgumentation "O étimo é o latim <i>umbĭlīcātus</i> (já atestado na \"História Natural\" de Plínio, conforme informa o Oxford Latin Dictionary). A conservação do -l- intervocálico demonstra tratar-se de forma erudita, sendo, portanto, um decalque do latim. Apesar de ter uma base morfológica (substantivo <i>umbigo</i>, já atestada em 1563), a forma esperada por derivação sufixal seria <i>*umbigado</i>; assim, evidencia-se que Vandelli e Brotero recuperaram a forma latina como base para a forma em língua portuguesa."^^rdf:HTML .

dbres:etymon_umbilicatus a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source dbsrc:source_old ;
    ontolex:writtenRep "umbilicatus" .

dbres:form_umbilicado a ontolex:Form ;
    ontolex:writtenRep "umbilicado"@pt .

dbres:form_umbilicada a ontolex:Form ;
    rdfs:label "feminino singular"@pt ;
    ontolex:writtenRep "Umbilicada"@pt .

dbres:form_umbilicadas a ontolex:Form ;
    rdfs:label "feminino plural"@pt ;
    ontolex:writtenRep "umbilicadas"@pt .

dbres:entry_umbilicado_sense1 a ontolex:LexicalSense ;
    skos:definition "Que possui uma concavidade semelhante a um umbigo, no centro."@pt ;
    lemonety:etymology dbres:etym_umbilicado_sense1 .

