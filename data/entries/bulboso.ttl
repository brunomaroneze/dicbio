### --- VERBETE: BULBOSO ---

dbres:entry_bulboso a ontolex:LexicalEntry ;
    dcterms:created "2022-02-28"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze ;
    lexinfo:partOfSpeech lexinfo:adjective ;
    ontolex:canonicalForm dbres:form_bulboso ;
    ontolex:otherForm dbres:form_bulbosa,
        dbres:form_bulbosas,
        dbres:form_bulbosos ;
    ontolex:sense dbres:entry_bulboso_sense1 .

dbres:etym_bulboso_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_bulbosus ;
    dicbio:etymologicalArgumentation "É possível considerar o termo como tendo se formado por derivação sufixal a partir de “bulbo”, bem como também considerar um empréstimo direto do latim <i>bulbosus,a,um</i>, já empregado no latim científico, conforme atesta o dicionário de Vandelli."^^rdf:HTML .

dbres:etymon_bulbosus a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source dbsrc:source_vandelli ;
    ontolex:writtenRep "bulbosus" .

dbres:form_bulboso a ontolex:Form ;
    ontolex:writtenRep "bulboso"@pt .

dbres:form_bulbosa a ontolex:Form ;
    rdfs:label "feminino singular"@pt ;
    ontolex:writtenRep "bulbosa"@pt .

dbres:form_bulbosas a ontolex:Form ;
    rdfs:label "feminino plural"@pt ;
    ontolex:writtenRep "bulbosas"@pt .

dbres:form_bulbosos a ontolex:Form ;
    rdfs:label "masculino plural"@pt ;
    ontolex:writtenRep "bulbosos"@pt .

dbres:entry_bulboso_sense1 a ontolex:LexicalSense ;
    skos:definition "Que tem forma de bulbo."@pt ;
    lemonety:etymology dbres:etym_bulboso_sense1 .

