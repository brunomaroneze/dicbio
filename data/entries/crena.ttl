### --- VERBETE: CRENA ---

dbres:entry_crena a ontolex:LexicalEntry ;
    dcterms:created "2022-02-28"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze ;
    lexinfo:gender lexinfo:feminine ;
    lexinfo:partOfSpeech lexinfo:noun ;
    ontolex:canonicalForm dbres:form_crena ;
    ontolex:otherForm dbres:form_crenas ;
    ontolex:sense dbres:entry_crena_sense1 .

dbres:etym_crena_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_crena ;
    dicbio:etymologicalArgumentation "O étimo é o latim científico <i>crena,ae</i>, com o mesmo significado, conforme se observa na própria obra de Vandelli. O Dicionário Houaiss afirma que a palavra era empregada no latim tardio com o sentido de “entalhe, fenda”."^^rdf:HTML .

dbres:etymon_crena a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source "Vandelli" ;
    ontolex:writtenRep "crena" .

dbres:form_crena a ontolex:Form ;
    ontolex:writtenRep "crena"@pt .

dbres:form_crenas a ontolex:Form ;
    rdfs:label "plural"@pt ;
    ontolex:writtenRep "crenas"@pt .

dbres:entry_crena_sense1 a ontolex:LexicalSense ;
    skos:definition "Incisura perpendicular obtusa na margem de certas folhas."@pt ;
    lemonety:etymology dbres:etym_crena_sense1 .

