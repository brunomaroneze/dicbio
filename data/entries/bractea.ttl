### --- VERBETE: BRACTEA ---

dbres:entry_bractea a ontolex:LexicalEntry ;
    dcterms:created "2022-02-28"^^xsd:date ;
    dcterms:creator dbauth:bruno_maroneze ;
    lexinfo:gender lexinfo:feminine ;
    lexinfo:partOfSpeech lexinfo:noun ;
    ontolex:canonicalForm dbres:form_bractea ;
    ontolex:otherForm dbres:form_bractea,
        dbres:form_bracteas ;
    ontolex:sense dbres:entry_bractea_sense1 .

dbres:etym_bractea_sense1 a lemonety:Etymology ;
    lemonety:etymon dbres:etymon_bractea ;
    dicbio:etymologicalArgumentation "O étimo é o latim científico <i>bractea</i>, já com o sentido usual da Botânica. No latim da Antiguidade, conforme informa o dicionário de Gaffiot, a palavra designava \"folha de metal, de ouro\"."^^rdf:HTML .

dbres:etymon_bractea a lemonety:Etymon ;
    dcterms:language <http://www.lexvo.org/page/iso639-3/lat> ;
    dcterms:source dbsrc:source_vandelli ;
    ontolex:writtenRep "bractea" .

dbres:form_bractea a ontolex:Form ;
    ontolex:writtenRep "bractea"@pt,
        "bractéa"@pt,
        "bráctea"@pt .

dbres:form_bracteas a ontolex:Form ;
    rdfs:label "plural"@pt ;
    ontolex:writtenRep "Bracteas"@pt,
        "Bractéas"@pt,
        "bracteas"@pt,
        "bractéas"@pt .

dbres:entry_bractea_sense1 a ontolex:LexicalSense ;
    skos:definition "Folha anexa à flor da florada seguinte, que se diferencia, em certos aspectos, das demais folhas."@pt ;
    lemonety:etymology dbres:etym_bractea_sense1 .

